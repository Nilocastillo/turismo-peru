---
const { day, title } = Astro.props;
---

<div class="relative pl-14 mb-10 last:mb-0">
  <!-- Línea vertical con degradado (color → transparente) -->
  <span
    class="absolute left-5 top-11 bottom-0 w-px bg-gradient-to-b from-secondary/25 to-secondary/0"
    aria-hidden="true"
  ></span>

  <!-- Círculo del día -->
  <span
    class="absolute left-0 top-0 w-10 h-10 rounded-full bg-secondary flex items-center justify-center text-white text-sm font-bold shadow-sm"
  >
    {day}
  </span>

  <!-- Contenido del día -->
  <div class="pt-0.5">
    <h3 class="text-xl md:text-2xl font-semibold text-secondary mb-3">
      {title}
    </h3>
    <div class="text-secondary/70 leading-relaxed space-y-3 text-pretty">
      <slot />
    </div>
  </div>
</div>
