---
const navItems = [
  { text: "EASY MACHUPICCHU", href: "/easy-machupicchu", featured: true },
  { text: "AVENTURA", href: "/aventura" },
  { text: "FULL DAY", href: "/fullday" },
  { text: "CULTURAL", href: "/cultural" },
  { text: "LUJO", href: "/lujo" },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white"
  data-scroll="false"
>
  <div class="max-w-7xl mx-auto px-6 py-3 lg:py-5 relative">
    <!-- Desktop layout -->
    <div class="hidden md:flex items-center justify-center gap-12 lg:gap-16">
      <div class="flex items-center gap-5 lg:gap-6">
        {
          navItems.slice(0, 2).map((item) => (
            <a
              href={item.href.startsWith("/") ? item.href : `/${item.href}`}
              class={`relative text-sm font-semibold uppercase tracking-[0.15em] transition-all duration-300 ${
                item.featured
                  ? "border border-primary-accessible text-primary-accessible hover:bg-primary-accessible hover:text-white rounded-full px-5 py-1.5"
                  : "nav-link text-secondary hover:text-primary-accessible/80 px-2 py-1.5"
              }`}
            >
              {item.text}
            </a>
          ))
        }
      </div>

      <div class="flex flex-col items-center logo-container">
        <a href="/" class="block">
          <img
            src="/tpc-logo-vertical.svg"
            alt="logo turismo Per\u00fa Consultores"
            width="284"
            height="160"
            class="h-12 lg:h-16 w-auto object-contain transition-transform duration-300"
            loading="eager"
          />
        </a>
        <p class="text-[10px] font-bold text-secondary/55 tracking-wider leading-none mt-1">RUC:20612570371</p>
      </div>

      <div class="flex items-center gap-5 lg:gap-6">
        {
          navItems.slice(2).map((item) => (
            <a
              href={item.href.startsWith("/") ? item.href : `/${item.href}`}
              class="relative text-sm font-semibold uppercase tracking-[0.15em] text-secondary hover:text-primary-accessible/80 nav-link px-2 py-1.5 transition-all duration-300"
            >
              {item.text}
            </a>
          ))
        }
      </div>
    </div>

    <!-- Mobile layout -->
    <div class="flex md:hidden items-center">
      <div class="flex-1"></div>
      <div class="flex flex-col items-center logo-container">
        <a href="/" class="block">
          <img
            src="/tpc-logo-vertical.svg"
            alt="logo turismo Per\u00fa Consultores"
            width="284"
            height="160"
            class="h-12 w-auto object-contain transition-transform duration-300"
            loading="eager"
          />
        </a>
        <p class="text-[10px] font-bold text-secondary/55 tracking-wider leading-none mt-1">RUC:20612570371</p>
      </div>
      <div class="flex-1 flex justify-end">
        <button
          aria-label="Abrir men\u00fa de navegaci\u00f3n"
          aria-controls="mobile-menu"
          aria-expanded="false"
          class="p-2 text-secondary focus:outline-none focus:ring-2 focus:ring-primary-accessible focus:ring-offset-2 z-20"
          id="mobile-menu-button"
        >
          <div class="w-6 h-5 relative flex flex-col justify-between" id="hamburger-icon">
            <span class="block h-0.5 w-full bg-current transition-all duration-300 origin-center rounded"></span>
            <span class="block h-0.5 w-full bg-current transition-all duration-300 rounded"></span>
            <span class="block h-0.5 w-full bg-current transition-all duration-300 origin-center rounded"></span>
          </div>
        </button>
      </div>
    </div>

    <!-- Scroll indicator line -->
    <div
      id="scroll-line"
      class="absolute bottom-0 left-6 right-6 h-[1px] bg-primary/25 opacity-0 transition-opacity duration-300 pointer-events-none"
    ></div>
  </div>

  <!-- Mobile menu -->
  <div
    class="md:hidden overflow-hidden"
    id="mobile-menu"
    data-open="false"
  >
    <div class="px-6 pb-6 pt-2 space-y-2 bg-white/95 backdrop-blur-lg">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`block py-3 px-4 text-sm font-semibold uppercase tracking-[0.15em] text-center transition-all duration-300 ${
              item.featured
                ? "border border-primary-accessible text-primary-accessible hover:bg-primary-accessible hover:text-white rounded-full"
                : "text-secondary hover:text-primary-accessible/80 rounded-md hover:bg-gray-50"
            }`}
          >
            {item.text}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<style>
  #main-nav[data-scroll="true"] {
    background-color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08), 0 2px 6px rgba(0, 0, 0, 0.04);
  }

  #main-nav[data-scroll="true"] #scroll-line {
    opacity: 1;
  }

  #main-nav[data-scroll="true"] .logo-container img {
    transform: scale(0.85);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 4px;
    left: 50%;
    width: 0;
    height: 1px;
    background: var(--color-primary);
    transition: width 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
    transform: translateX(-50%);
  }

  .nav-link:hover::after {
    width: calc(100% - 1rem);
  }

  .hamburger-open span:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }

  .hamburger-open span:nth-child(2) {
    opacity: 0;
  }

  .hamburger-open span:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  /* Mobile menu open/close */
  #mobile-menu {
    max-height: 0;
    transition: max-height 0.3s ease-in-out;
  }

  #mobile-menu[data-open="true"] {
    max-height: 400px;
  }
</style>

<script>
  let ac: AbortController | null = null;

  const initHeader = () => {
    // Cleanup previous listeners if the initializer runs more than once
    if (ac) ac.abort();
    ac = new AbortController();
    const { signal } = ac;

    const navbar = document.getElementById("main-nav");
    const menuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const hamburgerIcon = document.getElementById("hamburger-icon");

    // === Scroll handler (works independently of mobile menu) ===
    const handleScroll = () => {
      if (!navbar) return;
      if (window.scrollY > 50) {
        navbar.setAttribute("data-scroll", "true");
      } else {
        navbar.setAttribute("data-scroll", "false");
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true, signal });
    handleScroll();

    // === Mobile menu toggle ===
    if (menuButton && mobileMenu && hamburgerIcon) {
      menuButton.addEventListener(
        "click",
        (e) => {
          e.stopPropagation();
          const isOpen = mobileMenu.getAttribute("data-open") === "true";

          if (!isOpen) {
            mobileMenu.setAttribute("data-open", "true");
            hamburgerIcon.classList.add("hamburger-open");
            menuButton.setAttribute("aria-expanded", "true");
          } else {
            mobileMenu.setAttribute("data-open", "false");
            hamburgerIcon.classList.remove("hamburger-open");
            menuButton.setAttribute("aria-expanded", "false");
          }
        },
        { signal }
      );

      // Close mobile menu when clicking outside
      window.addEventListener(
        "click",
        (e) => {
          const target = e.target as Node;
          const isClickInside =
            (menuButton?.contains(target) ?? false) ||
            (mobileMenu?.contains(target) ?? false);

          if (mobileMenu?.getAttribute("data-open") === "true" && !isClickInside) {
            mobileMenu?.setAttribute("data-open", "false");
            hamburgerIcon?.classList.remove("hamburger-open");
            menuButton?.setAttribute("aria-expanded", "false");
          }
        },
        { signal }
      );

      // Close mobile menu on navigation (link click)
      const closeMenu = () => {
        if (!mobileMenu || !menuButton || !hamburgerIcon) return;
        if (mobileMenu.getAttribute("data-open") !== "true") return;
        mobileMenu.setAttribute("data-open", "false");
        hamburgerIcon.classList.remove("hamburger-open");
        menuButton.setAttribute("aria-expanded", "false");
      };

      mobileMenu.querySelectorAll("a").forEach((a) => {
        a.addEventListener("click", closeMenu, { signal });
      });

      window.addEventListener("hashchange", closeMenu, { signal });
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeader, { once: true });
  } else {
    initHeader();
  }
</script>
