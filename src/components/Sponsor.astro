---
import { Image } from "astro:assets";
import Iso9001 from "@/assets/img-sponsor/iso9001.webp";
import Iso14001 from "@/assets/img-sponsor/iso14001.webp";
import Iata from "@/assets/img-sponsor/iata.webp";
import MarcaPeru from "@/assets/img-sponsor/marcaperu.webp";
import TripAdvisor from "@/assets/img-sponsor/tripadvisor.webp";
import Gercetur from "@/assets/img-sponsor/gercetur.webp";
import SafeTravels from "@/assets/img-sponsor/safetravels.webp";
import TurismoResponsable from "@/assets/img-sponsor/turismoresponsable.webp";

const sponsors = [
  { logo: Iso9001, name: "Certificación ISO 9001", alt: "Logo de Certificación ISO 9001" },
  { logo: Iso14001, name: "Certificación ISO 14001", alt: "Logo de Certificación ISO 14001" },
  { logo: Iata, name: "Certificación IATA", alt: "Logo de Certificación IATA" },
  { logo: MarcaPeru, name: "Certificación Marca Peru", alt: "Logo de Certificación Marca Peru" },
  { logo: TripAdvisor, name: "Certificación TripAdvisor", alt: "Logo de Certificación TripAdvisor" },
  { logo: Gercetur, name: "Certificación Gercetur", alt: "Logo de Certificación Gercetur" },
  { logo: SafeTravels, name: "Certificación SafeTravels", alt: "Logo de Certificación SafeTravels" },
  { logo: TurismoResponsable, name: "Certificación Turismo Responsable", alt: "Logo de Certificación Turismo Responsable" },
];
---

<section class="py-12 md:py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Accent line -->
    <div class="w-16 h-px bg-primary mx-auto mb-6 animate-fade-in" />

    <div class="text-center">
      <span
        class="block text-xs font-semibold uppercase tracking-[0.3em] text-primary-accessible/60 mb-3 animate-fade-in-up"
      >
        RESPALDO
      </span>
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-bold text-secondary animate-fade-in-up delay-[100ms]"
      >
        Certificaciones y <span class="text-primary">Garantía</span>
      </h2>
      <p
        class="mt-4 text-base md:text-lg text-secondary/60 font-light max-w-2xl mx-auto animate-fade-in-up delay-[200ms]"
      >
        Respaldados por las principales certificaciones del sector turístico
        peruano e internacional
      </p>
    </div>

    <div
      class="mt-10 grid select-none grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 justify-items-center"
    >
      {
        sponsors.map((sponsor, i) => (
          <div
            class="company-link group relative flex h-24 w-24 items-center justify-center p-2 md:h-28 md:w-28 md:p-3 animate-fade-in-up"
            style={`animation-delay: ${(i + 1) * 100}ms`}
          >
            <!-- Corner brackets -->
            <span class="corner corner-tl" aria-hidden="true"></span>
            <span class="corner corner-tr" aria-hidden="true"></span>
            <span class="corner corner-bl" aria-hidden="true"></span>
            <span class="corner corner-br" aria-hidden="true"></span>
            <Image
              src={sponsor.logo}
              alt={sponsor.alt}
              widths={[96, 112, 128]}
              sizes="(min-width: 768px) 112px, 96px"
              class="max-h-full max-w-full object-contain transition duration-300 group-hover:scale-110 group-focus:scale-105"
              quality={95}
              format="webp"
              decoding="async"
              loading="lazy"
              fetchpriority="low"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
<style>
  /* --- Corner bracket lines --- */
  .corner {
    position: absolute;
    width: 20px;
    height: 20px;
    pointer-events: none;
    z-index: 2;
  }

  .corner::before,
  .corner::after {
    content: "";
    position: absolute;
    background: var(--color-primary);
    transition: all 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  /* Horizontal arms — start scaled 0 */
  .corner::before {
    height: 1.5px;
    transform: scaleX(0);
    transform-origin: var(--origin-h, left center);
  }

  /* Vertical arms — start scaled 0 */
  .corner::after {
    width: 1.5px;
    transform: scaleY(0);
    transform-origin: var(--origin-v, top center);
  }

  .group:hover .corner::before,
  .group:focus-within .corner::before {
    transform: scaleX(1);
  }
  .group:hover .corner::after,
  .group:focus-within .corner::after {
    transform: scaleY(1);
  }

  /* --- Top-Left --- */
  .corner-tl {
    top: -1px;
    left: -1px;
  }
  .corner-tl::before {
    top: 0;
    left: 0;
    width: 18px;
    --origin-h: left center;
  }
  .corner-tl::after {
    top: 0;
    left: 0;
    height: 18px;
    --origin-v: top center;
  }

  /* --- Top-Right --- */
  .corner-tr {
    top: -1px;
    right: -1px;
  }
  .corner-tr::before {
    top: 0;
    right: 0;
    width: 18px;
    --origin-h: right center;
  }
  .corner-tr::after {
    top: 0;
    right: 0;
    height: 18px;
    --origin-v: top center;
  }

  /* --- Bottom-Left --- */
  .corner-bl {
    bottom: -1px;
    left: -1px;
  }
  .corner-bl::before {
    bottom: 0;
    left: 0;
    width: 18px;
    --origin-h: left center;
  }
  .corner-bl::after {
    bottom: 0;
    left: 0;
    height: 18px;
    --origin-v: bottom center;
  }

  /* --- Bottom-Right --- */
  .corner-br {
    bottom: -1px;
    right: -1px;
  }
  .corner-br::before {
    bottom: 0;
    right: 0;
    width: 18px;
    --origin-h: right center;
  }
  .corner-br::after {
    bottom: 0;
    right: 0;
    height: 18px;
    --origin-v: bottom center;
  }

  @media (prefers-reduced-motion: reduce) {
    .corner::before,
    .corner::after {
      transition: none;
    }
    .group:hover .corner::before,
    .group:focus-within .corner::before {
      transform: scaleX(1);
    }
    .group:hover .corner::after,
    .group:focus-within .corner::after {
      transform: scaleY(1);
    }
  }
</style>
