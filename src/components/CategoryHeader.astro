---
interface Props {
  label: string;
  title: string;
  description: string;
}

const { label, title, description } = Astro.props;
---

<header
  class="max-w-3xl mx-auto text-center pt-24 md:pt-32 pb-12 md:pb-16"
>
  <div class="w-16 h-px bg-primary mx-auto mb-6" />
  <span
    class="block text-xs font-semibold uppercase tracking-[0.3em] text-primary-accessible/60 mb-3"
  >
    {label}
  </span>
  <h1
    class="text-balance text-4xl md:text-5xl lg:text-6xl font-bold text-secondary animate-fade-in-up"
  >
    {title}
  </h1>
  <p
    class="text-balance text-base md:text-lg text-secondary/70 max-w-2xl mx-auto mt-5 animate-fade-in-up delay-[100ms]"
  >
    {description}
  </p>
</header>
