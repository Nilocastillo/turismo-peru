---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  duration: string;
  category: string;
  href: string;
  image: ImageMetadata;
  alt: string;
}

const { title, duration, category, href, image, alt } = Astro.props as Props;
---

<article
  class="card-travel group h-full bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-500 hover:-translate-y-0.5"
>
  <a href={href} class="block h-full flex flex-col">
    <!-- Image container -->
    <div class="relative aspect-[16/9] shrink-0 overflow-hidden bg-secondary/5">
      <Image
        src={image}
        alt={alt}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
        widths={[320, 640, 800]}
        sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
        decoding="async"
        loading="lazy"
        fetchpriority="low"
      />

      <!-- Subtle gradient overlay at bottom of image -->
      <div class="absolute inset-0 bg-gradient-to-t from-secondary/20 to-transparent" />

      <!-- Category badge refined -->
      <div class="absolute bottom-3 left-3 z-10">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-white bg-white/10 backdrop-blur-md border border-white/20 rounded-full shadow-xs">
          <span class="w-1.5 h-1.5 bg-primary rounded-full" />
          {category}
        </span>
      </div>
    </div>

    <!-- Content below image -->
    <div class="p-4 md:p-5 flex-1 flex flex-col justify-between min-h-0">
      <div>
        <div class="flex items-center gap-1.5 mb-2.5">
          <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-[12px] font-semibold text-secondary/70 tracking-wide">{duration}</span>
        </div>

        <!-- Title -->
        <h2 class="text-base md:text-lg font-bold text-secondary leading-snug">
          {title}
        </h2>
      </div>

      <!-- Bottom row: accent line + CTA -->
      <div class="flex items-center justify-between pt-4">
        <div class="w-6 h-0.5 bg-primary/60 rounded-full transition-all duration-300 group-hover:w-8" />
        <span class="flex items-center gap-1 text-[12px] font-semibold uppercase tracking-[0.15em] text-primary-accessible/85 group-hover:text-primary-accessible transition-colors duration-300">
          Ver Tour
          <svg class="w-3 h-3 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>

<style>
  .card-travel {
    transform-style: preserve-3d;
  }

  @media (prefers-reduced-motion: reduce) {
    .card-travel * {
      animation: none;
      transition: none;
    }
  }
</style>
