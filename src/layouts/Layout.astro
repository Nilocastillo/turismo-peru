---
import "@/styles/global.css";
import "@fontsource-variable/outfit";

import Header from "@/components/Header.astro";
import WhatsAppFooter from "@/components/WhatsAppFooter.astro";
import Footer from "@/components/Footer.astro";
import Schema from "@/components/Schema.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  robots?: string;
  ogImage?: string;
}

const siteName = "Turismo Perú Consultores";
const fixedTitle = `${siteName} - Agencia de Viajes a Perú`;

const {
  title = fixedTitle,
  description = "Turismo Perú Consultores. expertos en viajes personalizados, sostenibles y auténticos por Perú. Vive experiencias inolvidables en Machu Picchu, Cusco, Lima, la Amazonía y más.",
  canonical = Astro.url?.toString() || "https://www.turismoperu.com.pe",
  robots = "index, follow",
  ogImage = "https://www.turismoperu.com.pe/og.jpg",
} = Astro.props;

const pageTitle = title ? `${title}` : fixedTitle;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO básico -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <meta
      name="keywords"
      content="agencia de viajes en Perú, viajes personalizados, turismo sostenible, tours en Machu Picchu, experiencias únicas, viajes a Cusco, viajes a Lima, paquetes turísticos Perú, turismo cultural, aventura en Perú, viaje a la Amazonía, agencia de turismo, Turismo Perú Consultores"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@turismoperupe" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="manifest" href="/manifest.json" />
    <Schema
      data={{
        "@context": "https://schema.org",
        "@type": "TravelAgency",
        name: siteName,
        image: ogImage,
        description: description,
        url: canonical,
        logo: "https://www.turismoperu.com.pe/tpc-logo-vertical.svg",
        telephone: "+51984209980",
        address: {
          "@type": "PostalAddress",
          streetAddress:
            "Calle Ollantaytambo D-11, Oficina 100 Edificio Atenas, Urbanización Manuel Prado",
          addressLocality: "Cusco",
          addressRegion: "Cusco",
          postalCode: "08000",
          addressCountry: "PE",
        },
        sameAs: [
          "https://www.facebook.com/turismoperuconsultores",
          "https://www.instagram.com/turismoperuconsultores/",
          "https://x.com/turismoperupe",
        ],
      }}
    />
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-6 focus:py-3 focus:bg-white focus:text-primary-accessible focus:rounded-lg focus:ring-2 focus:ring-primary-accessible focus:shadow-lg focus:text-sm focus:font-bold"
    >
      Saltar al contenido principal
    </a>
    <Header />
    <slot />
    <WhatsAppFooter />
    <Footer />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    max-width: 100%;
    overflow-x: clip;
  }
</style>
