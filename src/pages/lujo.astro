---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import Card from "@/components/Card.astro";
import CategoryHeader from "@/components/CategoryHeader.astro";
import { lujo } from "@/consts/pageTitles";

const tours = (await getCollection("tours")).filter(
  (tour) => tour.data.category.toLowerCase() === "lujo"
);

const description =
  "Viva el Perú en su máxima expresión con viajes de lujo: tren Hiram Bingham, hoteles 5 estrellas y experiencias personalizadas en Machu Picchu y Cusco.";
const canonical = "https://www.turismoperu.com.pe/lujo";
---

<Layout title={lujo} description={description} canonical={canonical}>
  <main>
    <CategoryHeader
      label="LUJO"
      title="Experiencias de Lujo en Perú"
      description="Disfruta de Tours de Lujo, Experiencia Exclusiva, Hoteles Premium, el Tren Hiram Bingham, Gastronomía de primer nivel, Experiencia VIP, Suites y Confort, Viaje Privado, Servicios Exclusivos y total Relax y Bienestar."
    />
    <section
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 md:pb-16 grid gap-4 md:grid-cols-2 lg:grid-cols-3"
      aria-label="Tours de Lujo"
    >
      {
        tours.map((tour) => (
          <Card
            title={tour.data.title}
            duration={tour.data.duration}
            category={tour.data.category}
            href={`/tours/${tour.id}/`}
            image={tour.data.image}
            alt={tour.data.alt}
          />
        ))
      }
    </section>
  </main>
</Layout>
