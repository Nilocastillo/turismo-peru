---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import Card from "@/components/Card.astro";
import CategoryHeader from "@/components/CategoryHeader.astro";
import { fullday } from "@/consts/pageTitles";

const tours = (await getCollection("tours")).filter(
  (tour) => tour.data.category.toLowerCase() === "full day"
);

const description =
  "Descubre los mejores tours Full Day en Perú: excursiones de 1 día con transporte, guía profesional y visitas a Paracas, Huacachina, Ica, Lima, Cusco y otros destinos imperdibles. Explora la cultura, naturaleza y aventuras en un solo día con experiencias completas y cómodas para viajeros de todo el mundo.";
const canonical = "https://www.turismoperu.com.pe/fullday";
---

<Layout title={fullday} description={description} canonical={canonical}>
  <main>
    <CategoryHeader
      label="FULL DAY"
      title="Experiencias Full Day en Perú"
      description="Vive las mejores experiencias de aventura Full Day en Perú con tours de trekking en los Andes, senderismo de montaña, rafting y kayak en ríos andinos, ciclismo de aventura, eco-aventura y rutas inolvidables por el Valle Sagrado."
    />
    <section
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 md:pb-16 grid gap-4 md:grid-cols-2 lg:grid-cols-3"
      aria-label="Tours Full Day"
    >
      {
        tours.map((tour) => (
          <Card
            title={tour.data.title}
            duration={tour.data.duration}
            category={tour.data.category}
            href={`/tours/${tour.id}/`}
            image={tour.data.image}
            alt={tour.data.alt}
          />
        ))
      }
    </section>
  </main>
</Layout>
