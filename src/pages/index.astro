---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero.astro";
import CodigoEsna from "@/components/CodigoEsna.astro";
import Sponsor from "@/components/Sponsor.astro";
import Clientes from "@/components/Clientes.astro";

import { getCollection } from "astro:content";
import CulturalBento from "@/components/CulturalBento.astro";

const tours = await getCollection("tours");
const culturalTours = tours.filter((t) => t.data.category === "cultural");

export const prerender = true;
---

<Layout
  title="Turismo Perú Consultores - Agencia de Viajes en Perú y Machu Picchu"
  description="Agencia de viajes en Perú con experiencias auténticas. Viajes a Machu Picchu, Cusco, Lima y Amazonía. Turismo sostenible y personalizado."
  canonical="https://www.turismoperu.com.pe/"
>
  <main id="main-content">
    <Hero />
    <CodigoEsna />
    <section class="bg-white max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="w-16 h-px bg-primary mx-auto mb-6 animate-fade-in" />
      <div class="text-center">
        <span class="block text-xs font-semibold uppercase tracking-[0.3em] text-primary-accessible/60 mb-3 animate-fade-in-up">EXPERIENCIAS</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-secondary animate-fade-in-up delay-[100ms]">
          Tours Culturales
        </h2>
      </div>
      <CulturalBento tours={culturalTours.slice(0, 5)} />
    </section>
    <Sponsor />
    <Clientes />
  </main>
</Layout>
