---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import Card from "@/components/Card.astro";
import CategoryHeader from "@/components/CategoryHeader.astro";
import { cultural } from "@/consts/pageTitles";

const tours = (await getCollection("tours")).filter(
  (tour) => tour.data.category.toLowerCase() === "cultural"
);

const description =
  "Descubre la riqueza cultural del Perú con tours que incluyen Cusco, Machu Picchu y experiencias auténticas en comunidades y sitios históricos.";
const canonical = "https://www.turismoperu.com.pe/cultural";
---

<Layout title={cultural} description={description} canonical={canonical}>
  <main>
    <CategoryHeader
      label="CULTURAL"
      title="Experiencias Culturales en Perú"
      description="Sumérgete en nuestras Experiencias Culturales, Arte y Tradición, Patrimonio Inca, Tours Guiados, Museos, Cultura Andina, Tradiciones Vivas, Festividades Locales y la impresionante Arquitectura Colonial."
    />
    <section
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 md:pb-16 grid gap-4 md:grid-cols-2 lg:grid-cols-3"
      aria-label="Tours Culturales"
    >
      {
        tours.map((tour) => (
          <Card
            title={tour.data.title}
            duration={tour.data.duration}
            category={tour.data.category}
            href={`/tours/${tour.id}/`}
            image={tour.data.image}
            alt={tour.data.alt}
          />
        ))
      }
    </section>
  </main>
</Layout>
