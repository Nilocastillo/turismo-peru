---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import Card from "@/components/Card.astro";
import CategoryHeader from "@/components/CategoryHeader.astro";

import { aventura } from "@/consts/pageTitles";

const tours = (await getCollection("tours")).filter(
  (tour) => tour.data.category.toLowerCase() === "aventura"
);

const description =
  "Explora Perú con nuestros tours de aventura: trekking, montañas, lagunas y experiencias únicas en contacto con la naturaleza.";
const canonical = "https://www.turismoperu.com.pe/aventura";
---

<Layout title={aventura} description={description} canonical={canonical}>
  <main>
    <CategoryHeader
      label="AVENTURA"
      title="Experiencias de Aventura en Perú"
      description="Ofrecemos una amplia variedad de experiencias como Tours de Aventura, Trekking en Perú, Senderismo en los Andes, Rafting y Kayak, Ciclismo, Rutas en Valle Sagrado, Aventura Extrema, Eco-Aventura y la oportunidad de Explorar Machu Picchu."
    />
    <section
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 md:pb-16 grid gap-4 md:grid-cols-2 lg:grid-cols-3"
      aria-label="Tours de Aventura"
    >
      {
        tours.map((tour) => (
          <Card
            title={tour.data.title}
            duration={tour.data.duration}
            category={tour.data.category}
            href={`/tours/${tour.id}/`}
            image={tour.data.image}
            alt={tour.data.alt}
          />
        ))
      }
    </section>
  </main>
</Layout>
